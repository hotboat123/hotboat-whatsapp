 # 🧪 STAGING/BETA Environment Variables Template
# Copia este contenido a Railway como variables de entorno para staging

# ============================================
# IMPORTANTE: AMBIENTE DE PRUEBAS
# No uses datos de clientes reales aquí
# ============================================

# Environment (DEBE ser "staging" o "beta")
ENVIRONMENT=staging

# Database - USAR BASE DE DATOS SEPARADA
# Opción A: Base de datos completamente separada (RECOMENDADO)
DATABASE_URL=postgresql://user:password@host:port/dbname_staging

# Opción B: Mismo DB pero schema diferente
# DATABASE_URL=postgresql://user:password@host:port/dbname?options=-c%20search_path=staging

# WhatsApp Business API (Meta)
# OPCIÓN A: Mismo número (más simple, pero comparte webhook)
WHATSAPP_API_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
WHATSAPP_VERIFY_TOKEN=staging_verify_token_DIFFERENT

# OPCIÓN B: Número de prueba de Meta (IDEAL)
# Usa el número de prueba que Meta te da en su dashboard
# WHATSAPP_API_TOKEN=your_test_token_here
# WHATSAPP_PHONE_NUMBER_ID=test_phone_id_from_meta
# WHATSAPP_BUSINESS_ACCOUNT_ID=test_account_id
# WHATSAPP_VERIFY_TOKEN=staging_verify_token

# AI (Groq - puedes usar la misma key)
GROQ_API_KEY=your_groq_api_key_here

# Bot Configuration - Identificadores de BETA
BOT_NAME=HotBoat Chile [BETA]
BUSINESS_NAME=Hot Boat Villarrica [PRUEBAS]

# Meta Pixel: deja vacío en staging para no mezclar datos con prod.
# META_PIXEL_ID=

# Automations - Tu número personal para pruebas
# NO uses números de clientes
AUTOMATION_PHONE_NUMBERS=56912345678

# Email Notifications (Opcional)
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
NOTIFICATION_EMAILS=

# Server Config
PORT=8000
LOG_LEVEL=DEBUG
