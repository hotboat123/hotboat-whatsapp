# =============================================================================
# hotboat-whatsapp — plantilla de entorno
# Copia:  cp .env.example .env
# Rellena valores reales. No subas .env al repositorio.
#
# Solo se listan variables que reconoce app/config.py (Settings).
# Otras (Mercado Pago, WooCommerce, ADMIN_PHONE, etc.) se leen con os.getenv
# en distintos módulos: configúralas en el panel del host (Railway, etc.) o
# amplía Settings con extra="ignore" si quieres mantenerlas en .env.
# =============================================================================

# --- Obligatorias (sin esto la app no arranca) -------------------------------

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

WHATSAPP_API_TOKEN=replace_with_meta_permanent_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_with_waba_id
WHATSAPP_VERIFY_TOKEN=choose_a_random_secret_for_webhook_verify

GROQ_API_KEY=replace_with_groq_api_key

# --- Servidor ---------------------------------------------------------------

PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Marca / bot ------------------------------------------------------------

BOT_NAME=Capitan HotBoat
BUSINESS_NAME=Mi negocio
BUSINESS_PHONE=+56 9 00000000
BUSINESS_EMAIL=info@example.com
BUSINESS_WEBSITE=https://example.com/

AUTOMATION_PHONE_NUMBERS=

# --- Correo (Resend) --------------------------------------------------------

EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
RESEND_FROM_CONFIRMATIONS=
RESEND_BCC_BOOKING=
NOTIFICATION_EMAILS=
EMAIL_LOGO_URL=

# --- SMTP (alternativa a Resend) -------------------------------------------

EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_USE_TLS=
EMAIL_USE_SSL=

# =============================================================================
# Referencia — no forman parte de Settings hoy; útiles en producción (host)
# =============================================================================
#
# PUBLIC_BASE_URL / APP_URL     → enlaces de pago y webhooks
# MERCADOPAGO_ACCESS_TOKEN      → app/booking/router.py
# ADMIN_PHONE                   → notificaciones WhatsApp (ej. 56912345678)
# ADMIN_EMAIL                   → app/booking/content_router.py
# WOO_URL, WOO_CK, WOO_CS, WOO_WEBHOOK_SECRET  → app/payment/woocommerce.py
# RAILWAY_PUBLIC_DOMAIN         → algunos templates de correo
#
