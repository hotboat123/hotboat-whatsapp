# Ignore all files in media directories
*

# But keep the .gitignore file
!.gitignore

# And keep .gitkeep files to preserve directory structure
!.gitkeep

# Keep accommodation images (if you want to version them)
# Uncomment the lines below if you want to track accommodation images in git:
# !accommodations/
# !accommodations/*.jpg
# !accommodations/*.png
# !accommodations/*.jpeg
# !accommodations/*.webp

# Keep documents directory with PDFs and READMEs
!documents/
!documents/*.pdf
!documents/*.md
!accommodations/*.md

# Experiencias: estructura, README e imágenes
!images/
!images/experiencias/
!images/experiencias/**/*.md
!images/experiencias/**/.gitkeep
!images/experiencias/**/*.jpg
!images/experiencias/**/*.jpeg
!images/experiencias/**/*.png
!images/experiencias/**/*.webp

# Alojamientos: imágenes
!images/alojamientos/
!images/alojamientos/**
!images/alojamientos/**/*.jpg
!images/alojamientos/**/*.jpeg
!images/alojamientos/**/*.png
!images/alojamientos/**/*.webp

# Packs: imágenes y estructura
!images/packs/
!images/packs/**
!images/packs/**/*.jpg
!images/packs/**/*.jpeg
!images/packs/**/*.png
!images/packs/**/*.webp